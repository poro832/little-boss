# AI API (로컬 개발용)
GEMINI_API_KEY=your_gemini_api_key_here

# 사용할 AI 선택: gemini(로컬) | bedrock(Lambda 프로덕션 권장)
AI_PROVIDER=gemini

# 로컬 개발 환경 설정
ENV=local   # local | production

# AWS - IAM Role 사용 (Access Key 발급 불가)
AWS_REGION=ap-northeast-2
S3_BUCKET=sgu-pj-03-littleboss-docs
DOCUMENTS_TABLE=sgu-pj-03-documents
USERS_TABLE=sgu-pj-03-users
CHECKLISTS_TABLE=sgu-pj-03-checklists

# AWS Bedrock (ap-northeast-2 차단 → us-east-1 사용)
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Google Calendar OAuth (Google Cloud Console에서 발급)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
